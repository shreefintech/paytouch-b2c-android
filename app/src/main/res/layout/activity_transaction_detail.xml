<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="onClickListener"
            type="android.view.View.OnClickListener" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/img_screen_bg"
        tools:context=".electricity.transactions.TransactionDetailActivity">

        <!-- Toolbar -->
        <include
            android:id="@+id/lytToolbar"
            layout="@layout/lyt_toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:onClickListener="@{onClickListener}" />

        <!-- Title row: "Transaction Status" + BharatConnect logo -->
        <LinearLayout
            android:id="@+id/llTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/page_margin_horizontal"
            android:layout_marginEnd="@dimen/page_margin_horizontal"
            android:layout_marginTop="@dimen/margin_medium"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lytToolbar">

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/proza_libre_bold"
                android:includeFontPadding="false"
                android:text="@string/titleTransactionStatus"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_size_20" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:src="@drawable/img_bharat_connect" />
        </LinearLayout>

        <!-- SMS Receipt button — fixed bottom -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvSmsReceipt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/page_margin_horizontal"
            android:layout_marginEnd="@dimen/page_margin_horizontal"
            android:layout_marginBottom="@dimen/page_margin_vertical"
            android:onClickListener="@{onClickListener}"
            app:cardBackgroundColor="@color/primary"
            app:cardCornerRadius="@dimen/normal_card_radius"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:fontFamily="@font/proza_libre_semi_bold"
                android:includeFontPadding="false"
                android:text="@string/tabSmsReceipt"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_14" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Glass card — fills remaining space -->
        <FrameLayout
            android:id="@+id/flCard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/page_margin_horizontal"
            android:layout_marginEnd="@dimen/page_margin_horizontal"
            android:layout_marginTop="@dimen/margin_medium"
            android:layout_marginBottom="@dimen/margin_medium"
            app:layout_constraintBottom_toTopOf="@id/cvSmsReceipt"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llTitle">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/margin_large"
                    android:paddingHorizontal="@dimen/margin_small_medium">

                    <!-- ── Card 1: Mobile / Status / Amount info ── -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/margin_medium"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="@dimen/normal_card_radius"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/colorPrimary"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/margin_small_medium">

                            <!-- Row 1: Mobile No. + Status badge -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tvMobileNumber"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/proza_libre_semi_bold"
                                    android:includeFontPadding="false"
                                    android:textColor="@color/black"
                                    android:textSize="@dimen/text_size_13"
                                    tools:text="Mobile No. 9876*****0" />

                                <!-- Status pill badge — CardView replaces drawable shape -->
                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/cvStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:strokeWidth="0dp"
                                    app:cardCornerRadius="20dp"
                                    app:cardElevation="0dp">

                                    <androidx.appcompat.widget.AppCompatTextView
                                        android:id="@+id/tvStatus"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="@font/proza_libre_semi_bold"
                                        android:includeFontPadding="false"
                                        android:paddingStart="10dp"
                                        android:paddingEnd="10dp"
                                        android:paddingTop="3dp"
                                        android:paddingBottom="3dp"
                                        android:textSize="@dimen/text_size_10"
                                        tools:text="Failed" />
                                </com.google.android.material.card.MaterialCardView>
                            </LinearLayout>

                            <!-- Row 2: Username + Amount -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/margin_small"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tvUsername"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/proza_libre_regular"
                                    android:includeFontPadding="false"
                                    android:textColor="#80000000"
                                    android:textSize="@dimen/text_size_13"
                                    tools:text="Username : Testuser" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tvInfoAmount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/proza_libre_bold"
                                    android:includeFontPadding="false"
                                    android:textColor="@color/primary"
                                    android:textSize="@dimen/text_size_18"
                                    tools:text="₹149.00" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ── Card 2: Payment details ── -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/margin_medium"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="@dimen/normal_card_radius"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/colorPrimary"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/margin_small_medium">

                            <!-- Header: rupee icon + "Payment" -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_width="@dimen/icon_small"
                                    android:layout_height="@dimen/icon_small"
                                    android:src="@drawable/ic_ruppes"
                                    android:tint="@color/primary" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/margin_extra_small"
                                    android:fontFamily="@font/proza_libre_bold"
                                    android:includeFontPadding="false"
                                    android:text="@string/labelPayment"
                                    android:textColor="@color/primary"
                                    android:textSize="@dimen/text_size_16" />
                            </LinearLayout>

                            <!-- Divider -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginTop="@dimen/margin_small"
                                android:layout_marginBottom="@dimen/margin_small"
                                android:background="@color/sheet_divider" />

                            <!-- Date row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/margin_extra_small"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/proza_libre_regular"
                                    android:includeFontPadding="false"
                                    android:text="@string/labelDate"
                                    android:textColor="#80000000"
                                    android:textSize="@dimen/text_size_13" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tvDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/proza_libre_regular"
                                    android:includeFontPadding="false"
                                    android:textColor="@color/black"
                                    android:textSize="@dimen/text_size_13"
                                    tools:text="18-07-2026, 09:15 am" />
                            </LinearLayout>

                            <!-- Amount row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/margin_small"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/proza_libre_regular"
                                    android:includeFontPadding="false"
                                    android:text="@string/labelAmount"
                                    android:textColor="#80000000"
                                    android:textSize="@dimen/text_size_13" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tvPaymentAmount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/proza_libre_regular"
                                    android:includeFontPadding="false"
                                    android:textColor="@color/black"
                                    android:textSize="@dimen/text_size_13"
                                    tools:text="₹149.00" />
                            </LinearLayout>

                            <!-- Platform Fee row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/margin_small"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/proza_libre_regular"
                                    android:includeFontPadding="false"
                                    android:text="@string/labelPlatformFee"
                                    android:textColor="#80000000"
                                    android:textSize="@dimen/text_size_13" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tvPlatformFee"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/proza_libre_regular"
                                    android:includeFontPadding="false"
                                    android:textColor="@color/black"
                                    android:textSize="@dimen/text_size_13"
                                    tools:text="₹3.00" />
                            </LinearLayout>

                            <!-- Total Payable row (primary + bold) -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/margin_small"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/proza_libre_semi_bold"
                                    android:includeFontPadding="false"
                                    android:text="@string/labelTotalPayable"
                                    android:textColor="@color/black"
                                    android:textSize="@dimen/text_size_13" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tvTotalPayable"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/proza_libre_bold"
                                    android:includeFontPadding="false"
                                    android:textColor="@color/primary"
                                    android:textSize="@dimen/text_size_13"
                                    tools:text="₹152.00" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ── Card 3: ID details ── -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/margin_medium"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="@dimen/normal_card_radius"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/colorPrimary"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/margin_small_medium">

                            <!-- Header: user icon + "ID" -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_width="@dimen/icon_small"
                                    android:layout_height="@dimen/icon_small"
                                    android:src="@drawable/ic_user"
                                    android:tint="@color/primary" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/margin_extra_small"
                                    android:fontFamily="@font/proza_libre_bold"
                                    android:includeFontPadding="false"
                                    android:text="@string/labelIdSection"
                                    android:textColor="@color/primary"
                                    android:textSize="@dimen/text_size_16" />
                            </LinearLayout>

                            <!-- Divider -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginTop="@dimen/margin_small"
                                android:layout_marginBottom="@dimen/margin_small"
                                android:background="@color/sheet_divider" />

                            <!-- Transaction ID row (value in primary color) -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/margin_extra_small"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/proza_libre_regular"
                                    android:includeFontPadding="false"
                                    android:text="@string/labelTransactionId"
                                    android:textColor="#80000000"
                                    android:textSize="@dimen/text_size_13" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tvTransactionId"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/proza_libre_semi_bold"
                                    android:includeFontPadding="false"
                                    android:textColor="@color/primary"
                                    android:textSize="@dimen/text_size_13"
                                    tools:text="BC88213045" />
                            </LinearLayout>

                            <!-- Reference ID row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/margin_small"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/proza_libre_regular"
                                    android:includeFontPadding="false"
                                    android:text="@string/labelReferenceId"
                                    android:textColor="#80000000"
                                    android:textSize="@dimen/text_size_13" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tvReferenceId"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/proza_libre_regular"
                                    android:includeFontPadding="false"
                                    android:textColor="@color/black"
                                    android:textSize="@dimen/text_size_13"
                                    tools:text="TXN10235" />
                            </LinearLayout>

                            <!-- User ID row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/margin_small"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/proza_libre_regular"
                                    android:includeFontPadding="false"
                                    android:text="@string/labelUserIdDetail"
                                    android:textColor="#80000000"
                                    android:textSize="@dimen/text_size_13" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tvUserId"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/proza_libre_regular"
                                    android:includeFontPadding="false"
                                    android:textColor="@color/black"
                                    android:textSize="@dimen/text_size_13"
                                    tools:text="-" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </ScrollView>
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
