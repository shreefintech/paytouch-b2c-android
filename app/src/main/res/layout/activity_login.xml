<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="onClickListener"
            type="android.view.View.OnClickListener" />

        <variable
            name="showProgress"
            type="androidx.databinding.ObservableBoolean" />

        <import type="android.view.View"/>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/img_screen_bg">

        <!-- ── Wallet illustration (top-right, all decorative elements in one image) ── -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivWalletIllustration"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:layout_marginTop="@dimen/margin_medium"
            android:scaleType="fitEnd"
            android:src="@drawable/img_wallet_recolored"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- ── PayTouch logo ── -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivLogo"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginStart="@dimen/page_margin_horizontal"
            android:layout_marginTop="@dimen/margin_medium"
            android:scaleType="fitStart"
            android:src="@drawable/img_paytouch"
            app:layout_constraintEnd_toStartOf="@id/ivWalletIllustration"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.55" />

        <!-- ── Welcome Back! ── -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/page_margin_horizontal"
            android:layout_marginTop="@dimen/margin_extra_large"
            android:text="@string/welcome_back"
            android:textColor="?attr/colorTextOnBrand"
            android:ellipsize="end"
            android:fontFamily="@font/proza_libre_bold"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:textSize="@dimen/text_size_22"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivLogo" />

        <!-- ── Subtitle ── -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/page_margin_horizontal"
            android:layout_marginTop="@dimen/margin_extra_small"
            android:layout_marginEnd="@dimen/margin_extra_small"
            android:text="@string/login_subtitle"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="3"
            android:fontFamily="@font/proza_libre_medium"
            android:textColor="?attr/colorTextOnBrand"
            android:textSize="@dimen/text_size_14"
            app:layout_constraintEnd_toStartOf="@id/ivWalletIllustration"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvWelcome" />

        <!-- ── Glass card ── -->
        <FrameLayout
            android:id="@+id/flCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_xxlarge"
            android:layout_marginHorizontal="@dimen/page_margin_horizontal"
            android:clipToOutline="true"
            android:outlineProvider="background"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintVertical_bias="0.0">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/page_margin_horizontal">

                    <!-- Mobile Number label -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_mobile_number"
                        android:fontFamily="@font/proza_libre_semi_bold"
                        android:textColor="@color/primary"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:textSize="@dimen/text_size_13" />

                    <!-- Mobile input -->
                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/etMobile"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/margin_small"
                        android:background="@drawable/bg_input_field"
                        android:hint="@string/hint_mobile"
                        android:textColorHint="?attr/colorTextHint"
                        android:inputType="phone"
                        android:ellipsize="end"
                        android:fontFamily="@font/proza_libre_medium"
                        android:maxLines="1"
                        android:includeFontPadding="false"
                        android:maxLength="10"
                        android:paddingHorizontal="@dimen/margin_small"
                        android:singleLine="true"
                        android:textColor="@color/black"
                        android:textSize="@dimen/text_size_13" />

                    <!-- Password / MPIN toggle -->
                    <LinearLayout
                        android:layout_width="220dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="@dimen/margin_large"
                        android:background="@drawable/bg_toggle_container"
                        android:clipToOutline="true"
                        android:orientation="horizontal"
                        android:outlineProvider="background">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvBtnPassword"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_toggle_selected"
                            android:gravity="center"
                            android:onClickListener="@{onClickListener}"
                            android:text="@string/label_password"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text_size_14"
                            android:ellipsize="end"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:fontFamily="@font/proza_libre_semi_bold"/>

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvBtnMpin"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_toggle_unselected"
                            android:gravity="center"
                            android:onClickListener="@{onClickListener}"
                            android:text="@string/label_mpin"
                            android:textColor="?colorPrimary"
                            android:textSize="@dimen/text_size_14"
                            android:ellipsize="end"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:fontFamily="@font/proza_libre_semi_bold" />

                    </LinearLayout>

                    <!-- Credential label -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvCredentialLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_large"
                        android:text="@string/label_password"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_size_13"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:fontFamily="@font/proza_libre_semi_bold" />

                    <!-- Credential input with eye toggle -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/margin_small"
                        android:background="@drawable/bg_input_field">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/etCredential"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:hint="@string/hint_password"
                            android:textColorHint="?attr/colorTextHint"
                            android:inputType="phone"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_medium"
                            android:maxLines="1"
                            android:includeFontPadding="false"
                            android:maxLength="10"
                            android:paddingHorizontal="@dimen/margin_small"
                            android:singleLine="true"
                            android:textColor="@color/black"
                            android:textSize="@dimen/text_size_13" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/ivPasswordToggle"
                            android:layout_width="@dimen/icon_small"
                            android:layout_height="@dimen/icon_small"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginEnd="@dimen/margin_large"
                            android:clickable="true"
                            android:focusable="true"
                            android:onClickListener="@{onClickListener}"
                            android:tint="@color/black"
                            android:src="@drawable/ic_eye_off" />

                    </FrameLayout>

                    <!-- Save Credentials + Forgot Password row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <androidx.appcompat.widget.AppCompatCheckBox
                            android:id="@+id/cbSaveCredentials"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_medium"
                            android:textColor="?attr/colorPrimary"
                            android:text="@string/label_save_credentials"
                            android:textSize="@dimen/text_size_13" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvForgotPassword"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:onClickListener="@{onClickListener}"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:textColor="?attr/colorPrimary"
                            android:fontFamily="@font/proza_libre_medium"
                            android:text="@string/forgot_password"
                            android:textSize="@dimen/text_size_13" />

                    </LinearLayout>

                    <!-- Sign In button -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        app:cardBackgroundColor="?attr/colorPrimary"
                        app:cardElevation="@dimen/card_elevation"
                        app:cardCornerRadius="@dimen/button_corner_radius"
                        android:layout_marginTop="@dimen/margin_extra_large"
                        android:layout_marginBottom="@dimen/margin_small">

                        <LinearLayout
                            android:id="@+id/llSignIn"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clickable="true"
                            android:focusable="true"
                            android:onClickListener="@{onClickListener}"
                            android:visibility="@{showProgress ? View.INVISIBLE : View.VISIBLE}"
                            android:foreground="?selectableItemBackground"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_width="@dimen/icon_medium"
                                android:layout_height="@dimen/icon_medium"
                                android:layout_marginEnd="@dimen/margin_small_medium"
                                android:src="@drawable/ic_signin" />

                            <androidx.appcompat.widget.AppCompatTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sign_in"
                                android:textColor="@color/white"
                                android:textSize="@dimen/text_size_16"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/progressBar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginVertical="@dimen/margin_small"
                            android:visibility="@{showProgress ? View.VISIBLE : View.GONE}"
                            android:indeterminateTint="@color/white"
                            tools:visibility="gone" />

                    </androidx.cardview.widget.CardView>


                    <!-- ── Create Account section ── -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/llCreateAccountSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_extra_large"
                        android:gravity="center_vertical"
                        android:layout_gravity="center_horizontal"
                        android:orientation="horizontal"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/flCard">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvNewAccDes"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/proza_libre_medium"
                            android:includeFontPadding="true"
                            android:text="@string/no_account"
                            android:textAlignment="viewStart"
                            android:textColor="?attr/colorTextHint"
                            android:textSize="@dimen/text_size_12"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/cvCreateAccount"
                            app:layout_constraintHorizontal_bias="1.0"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cvCreateAccount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:strokeWidth="1dp"
                            app:cardCornerRadius="3dp"
                            app:strokeColor="?attr/colorPrimary"
                            app:layout_constraintStart_toEndOf="@id/tvNewAccDes"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <LinearLayout
                                android:id="@+id/llCreateAccount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="@dimen/margin_small"
                                android:paddingVertical="@dimen/margin_small"
                                android:clickable="true"
                                android:focusable="true"
                                android:onClickListener="@{onClickListener}"
                                android:gravity="center"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginEnd="4dp"
                                    android:src="@drawable/ic_create_account" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/create_account"
                                    android:textColor="@color/primary"
                                    android:includeFontPadding="false"
                                    android:fontFamily="@font/proza_libre_medium"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:textSize="@dimen/text_size_12" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>
        </FrameLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
