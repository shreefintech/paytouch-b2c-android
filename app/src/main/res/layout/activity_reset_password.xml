<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="onClickListener"
            type="android.view.View.OnClickListener" />

        <variable
            name="showProgress"
            type="androidx.databinding.ObservableBoolean" />

        <import type="android.view.View" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/img_screen_bg">

        <!-- ── Wallet illustration (top-right) ── -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivWalletIllustration"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:layout_marginTop="@dimen/margin_medium"
            android:scaleType="fitEnd"
            android:src="@drawable/img_wallet_recolored"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- ── PayTouch logo ── -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivLogo"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginStart="@dimen/page_margin_horizontal"
            android:layout_marginTop="@dimen/margin_medium"
            android:scaleType="fitStart"
            android:src="@drawable/img_paytouch"
            app:layout_constraintEnd_toStartOf="@id/ivWalletIllustration"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.55" />

        <!-- ── Reset Password ── -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/page_margin_horizontal"
            android:layout_marginTop="@dimen/margin_extra_large"
            android:ellipsize="end"
            android:fontFamily="@font/proza_libre_bold"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="@string/titleResetPassword"
            android:textColor="?attr/colorTextOnBrand"
            android:textSize="@dimen/text_size_22"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivLogo" />

        <!-- ── Subtitle ── -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/page_margin_horizontal"
            android:layout_marginTop="@dimen/margin_extra_small"
            android:layout_marginEnd="@dimen/margin_extra_small"
            android:ellipsize="end"
            android:fontFamily="@font/proza_libre_medium"
            android:includeFontPadding="false"
            android:maxLines="3"
            android:text="@string/subtitleResetPassword"
            android:textColor="?attr/colorTextOnBrand"
            android:textSize="@dimen/text_size_14"
            app:layout_constraintEnd_toStartOf="@id/ivWalletIllustration"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <!-- ── Glass card ── -->
        <FrameLayout
            android:id="@+id/flCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/page_margin_horizontal"
            android:layout_marginTop="@dimen/margin_xxlarge"
            android:layout_marginBottom="@dimen/margin_medium"
            android:clipToOutline="true"
            android:outlineProvider="background"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintVertical_bias="0.0">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/page_margin_horizontal">

                    <!-- Password rules info box -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/margin_large"
                        android:background="@drawable/bg_info_box"
                        android:ellipsize="end"
                        android:fontFamily="@font/proza_libre_medium"
                        android:includeFontPadding="false"
                        android:maxLines="4"
                        android:padding="@dimen/margin_small_medium"
                        android:text="@string/msgPasswordRules"
                        android:textColor="@color/hint_color"
                        android:textSize="@dimen/text_size_12" />

                    <!-- New password label -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/proza_libre_semi_bold"
                        android:includeFontPadding="false"
                        android:text="@string/labelNewPassword"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_size_13" />

                    <!-- New password input with eye toggle -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/margin_small"
                        android:background="@drawable/bg_input_field">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/etNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_medium"
                            android:hint="@string/hintNewPassword"
                            android:includeFontPadding="false"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:paddingHorizontal="@dimen/margin_small"
                            android:singleLine="true"
                            android:textColor="@color/black"
                            android:textColorHint="?attr/colorTextHint"
                            android:textSize="@dimen/text_size_13" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/ivNewPasswordToggle"
                            android:layout_width="@dimen/icon_small"
                            android:layout_height="@dimen/icon_small"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginEnd="@dimen/margin_large"
                            android:clickable="true"
                            android:focusable="true"
                            android:onClickListener="@{onClickListener}"
                            android:src="@drawable/ic_eye_off"
                            android:tint="@color/black" />

                    </FrameLayout>

                    <!-- Confirm password label -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_large"
                        android:ellipsize="end"
                        android:fontFamily="@font/proza_libre_semi_bold"
                        android:includeFontPadding="false"
                        android:text="@string/label_confirm_password"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_size_13" />

                    <!-- Confirm password input with eye toggle -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/margin_small"
                        android:background="@drawable/bg_input_field">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_medium"
                            android:hint="@string/hintConfirmNewPassword"
                            android:includeFontPadding="false"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:paddingHorizontal="@dimen/margin_small"
                            android:singleLine="true"
                            android:textColor="@color/black"
                            android:textColorHint="?attr/colorTextHint"
                            android:textSize="@dimen/text_size_13" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/ivConfirmPasswordToggle"
                            android:layout_width="@dimen/icon_small"
                            android:layout_height="@dimen/icon_small"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginEnd="@dimen/margin_large"
                            android:clickable="true"
                            android:focusable="true"
                            android:onClickListener="@{onClickListener}"
                            android:src="@drawable/ic_eye_off"
                            android:tint="@color/black" />

                    </FrameLayout>

                    <!-- Change Password button -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/margin_extra_large"
                        android:layout_marginBottom="@dimen/margin_small"
                        app:cardBackgroundColor="?attr/colorPrimary"
                        app:cardCornerRadius="@dimen/button_corner_radius"
                        app:cardElevation="@dimen/card_elevation">

                        <LinearLayout
                            android:id="@+id/llChangePassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?selectableItemBackground"
                            android:gravity="center"
                            android:onClickListener="@{onClickListener}"
                            android:orientation="horizontal"
                            android:visibility="@{showProgress ? View.INVISIBLE : View.VISIBLE}">

                            <androidx.appcompat.widget.AppCompatTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/btnChangePassword"
                                android:textColor="@color/white"
                                android:textSize="@dimen/text_size_16"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/progressBar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginVertical="@dimen/margin_small"
                            android:indeterminateTint="@color/white"
                            android:visibility="@{showProgress ? View.VISIBLE : View.GONE}"
                            tools:visibility="gone" />

                    </androidx.cardview.widget.CardView>

                    <!-- Back to sign In Page -->
                    <LinearLayout
                        android:id="@+id/tvBackToSignIn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:layout_marginBottom="@dimen/margin_small"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?selectableItemBackground"
                        android:gravity="center_vertical"
                        android:onClickListener="@{onClickListener}"
                        android:orientation="horizontal">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="@dimen/icon_small"
                            android:layout_height="@dimen/icon_small"
                            android:src="@drawable/ic_signin"
                            android:tint="@color/black" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/margin_small"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_medium"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:text="@string/back_to_sign_in"
                            android:textColor="@color/black"
                            android:textSize="@dimen/text_size_13" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
