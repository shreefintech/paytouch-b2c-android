<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="onClickListener"
            type="android.view.View.OnClickListener" />

        <variable
            name="showProgress"
            type="androidx.databinding.ObservableBoolean" />

        <import type="android.view.View" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/img_screen_bg">

        <!-- ── Wallet illustration (top-right) ── -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivWalletIllustration"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:layout_marginTop="@dimen/margin_medium"
            android:scaleType="fitEnd"
            android:src="@drawable/img_wallet_recolored"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- ── PayTouch logo ── -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivLogo"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginStart="@dimen/page_margin_horizontal"
            android:layout_marginTop="@dimen/margin_medium"
            android:scaleType="fitStart"
            android:src="@drawable/img_paytouch"
            app:layout_constraintEnd_toStartOf="@id/ivWalletIllustration"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.55" />

        <!-- ── Reset MPIN ── -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/page_margin_horizontal"
            android:layout_marginTop="@dimen/margin_extra_large"
            android:ellipsize="end"
            android:fontFamily="@font/proza_libre_bold"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="@string/titleResetMpin"
            android:textColor="?attr/colorTextOnBrand"
            android:textSize="@dimen/text_size_22"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivLogo" />

        <!-- ── Subtitle ── -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/page_margin_horizontal"
            android:layout_marginTop="@dimen/margin_extra_small"
            android:layout_marginEnd="@dimen/margin_extra_small"
            android:ellipsize="end"
            android:fontFamily="@font/proza_libre_medium"
            android:includeFontPadding="false"
            android:maxLines="3"
            android:text="@string/subtitleResetMpin"
            android:textColor="?attr/colorTextOnBrand"
            android:textSize="@dimen/text_size_14"
            app:layout_constraintEnd_toStartOf="@id/ivWalletIllustration"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <!-- ── Glass card ── -->
        <FrameLayout
            android:id="@+id/flCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/page_margin_horizontal"
            android:layout_marginTop="@dimen/margin_xxlarge"
            android:layout_marginBottom="@dimen/margin_medium"
            android:clipToOutline="true"
            android:outlineProvider="background"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintVertical_bias="0.0">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/page_margin_horizontal">

                    <!-- MPIN rules info box -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/margin_large"
                        android:background="@drawable/bg_info_box"
                        android:ellipsize="end"
                        android:fontFamily="@font/proza_libre_medium"
                        android:includeFontPadding="false"
                        android:maxLines="4"
                        android:padding="@dimen/margin_small_medium"
                        android:text="@string/msgMpinRules"
                        android:textColor="@color/hint_color"
                        android:textSize="@dimen/text_size_12" />

                    <!-- New MPIN label -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/proza_libre_semi_bold"
                        android:includeFontPadding="false"
                        android:text="@string/labelNewMpin"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_size_13" />

                    <!-- New MPIN boxes row -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/clNewMpinBoxes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_small">

                        <!-- Box 1 -->
                        <FrameLayout
                            android:id="@+id/flNewMpin1"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginHorizontal="3dp"
                            android:background="@drawable/bg_otp_box"
                            android:clipToOutline="false"
                            android:outlineProvider="background"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <androidx.appcompat.widget.AppCompatEditText
                                android:id="@+id/etNewMpin1"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:cursorVisible="false"
                                android:fontFamily="@font/proza_libre_semi_bold"
                                android:gravity="center"
                                android:imeOptions="actionNext"
                                android:includeFontPadding="false"
                                android:inputType="number"
                                android:maxLength="1"
                                android:singleLine="true"
                                android:textColor="@color/black"
                                android:textSize="@dimen/text_size_22" />

                        </FrameLayout>

                        <!-- Box 2 -->
                        <FrameLayout
                            android:id="@+id/flNewMpin2"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginHorizontal="3dp"
                            android:background="@drawable/bg_otp_box"
                            android:clipToOutline="false"
                            android:outlineProvider="background"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/flNewMpin3"
                            app:layout_constraintStart_toEndOf="@id/flNewMpin1"
                            app:layout_constraintTop_toTopOf="parent">

                            <androidx.appcompat.widget.AppCompatEditText
                                android:id="@+id/etNewMpin2"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:cursorVisible="false"
                                android:fontFamily="@font/proza_libre_semi_bold"
                                android:gravity="center"
                                android:imeOptions="actionNext"
                                android:includeFontPadding="false"
                                android:inputType="number"
                                android:maxLength="1"
                                android:singleLine="true"
                                android:textColor="@color/black"
                                android:textSize="@dimen/text_size_22" />

                        </FrameLayout>

                        <!-- Box 3 -->
                        <FrameLayout
                            android:id="@+id/flNewMpin3"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginHorizontal="3dp"
                            android:background="@drawable/bg_otp_box"
                            android:clipToOutline="false"
                            android:outlineProvider="background"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/flNewMpin4"
                            app:layout_constraintStart_toEndOf="@id/flNewMpin2"
                            app:layout_constraintTop_toTopOf="parent">

                            <androidx.appcompat.widget.AppCompatEditText
                                android:id="@+id/etNewMpin3"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:cursorVisible="false"
                                android:fontFamily="@font/proza_libre_semi_bold"
                                android:gravity="center"
                                android:imeOptions="actionNext"
                                android:includeFontPadding="false"
                                android:inputType="number"
                                android:maxLength="1"
                                android:singleLine="true"
                                android:textColor="@color/black"
                                android:textSize="@dimen/text_size_22" />

                        </FrameLayout>

                        <!-- Box 4 -->
                        <FrameLayout
                            android:id="@+id/flNewMpin4"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginHorizontal="3dp"
                            android:background="@drawable/bg_otp_box"
                            android:clipToOutline="false"
                            android:outlineProvider="background"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <androidx.appcompat.widget.AppCompatEditText
                                android:id="@+id/etNewMpin4"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:cursorVisible="false"
                                android:fontFamily="@font/proza_libre_semi_bold"
                                android:gravity="center"
                                android:imeOptions="actionNext"
                                android:includeFontPadding="false"
                                android:inputType="number"
                                android:maxLength="1"
                                android:singleLine="true"
                                android:textColor="@color/black"
                                android:textSize="@dimen/text_size_22" />

                        </FrameLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Confirm MPIN label -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_extra_large"
                        android:ellipsize="end"
                        android:fontFamily="@font/proza_libre_semi_bold"
                        android:includeFontPadding="false"
                        android:text="@string/labelConfirmMpin"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_size_13" />

                    <!-- Confirm MPIN boxes row -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/clConfirmMpinBoxes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_small">

                        <!-- Box 1 -->
                        <FrameLayout
                            android:id="@+id/flConfirmMpin1"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginHorizontal="3dp"
                            android:background="@drawable/bg_otp_box"
                            android:clipToOutline="false"
                            android:outlineProvider="background"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <androidx.appcompat.widget.AppCompatEditText
                                android:id="@+id/etConfirmMpin1"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:cursorVisible="false"
                                android:fontFamily="@font/proza_libre_semi_bold"
                                android:gravity="center"
                                android:imeOptions="actionNext"
                                android:includeFontPadding="false"
                                android:inputType="number"
                                android:maxLength="1"
                                android:singleLine="true"
                                android:textColor="@color/black"
                                android:textSize="@dimen/text_size_22" />

                        </FrameLayout>

                        <!-- Box 2 -->
                        <FrameLayout
                            android:id="@+id/flConfirmMpin2"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginHorizontal="3dp"
                            android:background="@drawable/bg_otp_box"
                            android:clipToOutline="false"
                            android:outlineProvider="background"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/flConfirmMpin3"
                            app:layout_constraintStart_toEndOf="@id/flConfirmMpin1"
                            app:layout_constraintTop_toTopOf="parent">

                            <androidx.appcompat.widget.AppCompatEditText
                                android:id="@+id/etConfirmMpin2"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:cursorVisible="false"
                                android:fontFamily="@font/proza_libre_semi_bold"
                                android:gravity="center"
                                android:imeOptions="actionNext"
                                android:includeFontPadding="false"
                                android:inputType="number"
                                android:maxLength="1"
                                android:singleLine="true"
                                android:textColor="@color/black"
                                android:textSize="@dimen/text_size_22" />

                        </FrameLayout>

                        <!-- Box 3 -->
                        <FrameLayout
                            android:id="@+id/flConfirmMpin3"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginHorizontal="3dp"
                            android:background="@drawable/bg_otp_box"
                            android:clipToOutline="false"
                            android:outlineProvider="background"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/flConfirmMpin4"
                            app:layout_constraintStart_toEndOf="@id/flConfirmMpin2"
                            app:layout_constraintTop_toTopOf="parent">

                            <androidx.appcompat.widget.AppCompatEditText
                                android:id="@+id/etConfirmMpin3"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:cursorVisible="false"
                                android:fontFamily="@font/proza_libre_semi_bold"
                                android:gravity="center"
                                android:imeOptions="actionNext"
                                android:includeFontPadding="false"
                                android:inputType="number"
                                android:maxLength="1"
                                android:singleLine="true"
                                android:textColor="@color/black"
                                android:textSize="@dimen/text_size_22" />

                        </FrameLayout>

                        <!-- Box 4 -->
                        <FrameLayout
                            android:id="@+id/flConfirmMpin4"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginHorizontal="3dp"
                            android:background="@drawable/bg_otp_box"
                            android:clipToOutline="false"
                            android:outlineProvider="background"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <androidx.appcompat.widget.AppCompatEditText
                                android:id="@+id/etConfirmMpin4"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:cursorVisible="false"
                                android:fontFamily="@font/proza_libre_semi_bold"
                                android:gravity="center"
                                android:imeOptions="actionDone"
                                android:includeFontPadding="false"
                                android:inputType="number"
                                android:maxLength="1"
                                android:singleLine="true"
                                android:textColor="@color/black"
                                android:textSize="@dimen/text_size_22" />

                        </FrameLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Change MPIN button -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/margin_extra_large"
                        android:layout_marginBottom="@dimen/margin_small"
                        app:cardBackgroundColor="?attr/colorPrimary"
                        app:cardCornerRadius="@dimen/button_corner_radius"
                        app:cardElevation="@dimen/card_elevation">

                        <LinearLayout
                            android:id="@+id/llChangeMpin"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?selectableItemBackground"
                            android:gravity="center"
                            android:onClickListener="@{onClickListener}"
                            android:orientation="horizontal"
                            android:visibility="@{showProgress ? View.INVISIBLE : View.VISIBLE}">

                            <androidx.appcompat.widget.AppCompatTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/btnChangeMpin"
                                android:textColor="@color/white"
                                android:textSize="@dimen/text_size_16"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/progressBar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginVertical="@dimen/margin_small"
                            android:indeterminateTint="@color/white"
                            android:visibility="@{showProgress ? View.VISIBLE : View.GONE}"
                            tools:visibility="gone" />

                    </androidx.cardview.widget.CardView>

                    <!-- Back to sign In Page -->
                    <LinearLayout
                        android:id="@+id/tvBackToSignIn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:layout_marginBottom="@dimen/margin_small"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?selectableItemBackground"
                        android:gravity="center_vertical"
                        android:onClickListener="@{onClickListener}"
                        android:orientation="horizontal">


                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="@dimen/icon_small"
                            android:layout_height="@dimen/icon_small"
                            android:src="@drawable/ic_signin"
                            android:tint="@color/black" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/margin_small"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_medium"
                            android:includeFontPadding="false"
                            android:maxLines="1"
                            android:text="@string/back_to_sign_in"
                            android:textColor="@color/black"
                            android:textSize="@dimen/text_size_13" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
