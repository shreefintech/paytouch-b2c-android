<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="onClickListener"
            type="android.view.View.OnClickListener" />

        <variable
            name="showProgress"
            type="androidx.databinding.ObservableBoolean" />

        <import type="android.view.View" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/img_screen_bg">

        <!-- ── Toolbar ── -->
        <include
            android:id="@+id/lytToolbar"
            layout="@layout/lyt_toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:onClickListener="@{onClickListener}" />

        <!-- ── Glass card (fills remaining screen height) ── -->
        <FrameLayout
            android:id="@+id/flCard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/margin_medium"
            android:layout_marginHorizontal="@dimen/page_margin_horizontal"
            android:layout_marginBottom="@dimen/margin_medium"
            android:clipToOutline="true"
            android:outlineProvider="background"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lytToolbar">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- KYC Information form header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_info_box"
                        android:orientation="vertical"
                        android:padding="@dimen/margin_large">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/proza_libre_bold"
                            android:includeFontPadding="false"
                            android:text="@string/titleKycInfo"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_18" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/primary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/page_margin_horizontal">

                        <!-- Personal Information -->
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/proza_libre_semi_bold"
                            android:includeFontPadding="false"
                            android:text="@string/labelPersonalInformation"
                            android:textColor="@color/black"
                            android:textSize="@dimen/text_size_16" />

                        <!-- Mobile Number label -->
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_large"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_semi_bold"
                            android:includeFontPadding="false"
                            android:text="@string/label_mobile_number"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Mobile input -->
                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/etMobile"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/margin_small"
                            android:background="@drawable/bg_input_field"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_medium"
                            android:hint="@string/hint_mobile"
                            android:includeFontPadding="false"
                            android:inputType="phone"
                            android:maxLength="10"
                            android:maxLines="1"
                            android:paddingHorizontal="@dimen/margin_small"
                            android:singleLine="true"
                            android:textColor="@color/black"
                            android:textColorHint="?attr/colorTextHint"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Member Name label -->
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_large"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_semi_bold"
                            android:includeFontPadding="false"
                            android:text="@string/labelMemberName"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Member Name input -->
                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/etMemberName"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/margin_small"
                            android:background="@drawable/bg_input_field"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_medium"
                            android:hint="@string/hintMemberName"
                            android:includeFontPadding="false"
                            android:inputType="textPersonName|textCapWords"
                            android:maxLength="50"
                            android:maxLines="1"
                            android:paddingHorizontal="@dimen/margin_small"
                            android:singleLine="true"
                            android:textColor="@color/black"
                            android:textColorHint="?attr/colorTextHint"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Birthdate label -->
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_large"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_semi_bold"
                            android:includeFontPadding="false"
                            android:text="@string/labelBirthdate"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Birthdate "input" (opens DatePicker, not directly editable) -->
                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/etBirthdate"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/margin_small"
                            android:background="@drawable/bg_input_field"
                            android:clickable="true"
                            android:cursorVisible="false"
                            android:ellipsize="end"
                            android:focusable="true"
                            android:focusableInTouchMode="false"
                            android:fontFamily="@font/proza_libre_medium"
                            android:hint="@string/hintBirthdate"
                            android:includeFontPadding="false"
                            android:longClickable="false"
                            android:maxLines="1"
                            android:onClickListener="@{onClickListener}"
                            android:paddingHorizontal="@dimen/margin_small"
                            android:singleLine="true"
                            android:textColor="@color/black"
                            android:textColorHint="?attr/colorTextHint"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Age label -->
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_large"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_semi_bold"
                            android:includeFontPadding="false"
                            android:text="@string/labelAge"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Age (read-only, auto-calculated from Birthdate) -->
                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/etAge"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/margin_small"
                            android:background="@drawable/bg_input_field"
                            android:clickable="false"
                            android:cursorVisible="false"
                            android:ellipsize="end"
                            android:focusable="false"
                            android:fontFamily="@font/proza_libre_medium"
                            android:hint="@string/hintAge"
                            android:includeFontPadding="false"
                            android:longClickable="false"
                            android:maxLines="1"
                            android:paddingHorizontal="@dimen/margin_small"
                            android:singleLine="true"
                            android:textColor="@color/black"
                            android:textColorHint="?attr/colorTextHint"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Home Address label -->
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_large"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_semi_bold"
                            android:includeFontPadding="false"
                            android:text="@string/labelHomeAddress"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Home Address input -->
                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/etAddress"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/margin_small"
                            android:background="@drawable/bg_input_field"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_medium"
                            android:hint="@string/hintHomeAddress"
                            android:includeFontPadding="false"
                            android:inputType="textPostalAddress"
                            android:maxLength="200"
                            android:maxLines="1"
                            android:paddingHorizontal="@dimen/margin_small"
                            android:singleLine="true"
                            android:textColor="@color/black"
                            android:textColorHint="?attr/colorTextHint"
                            android:textSize="@dimen/text_size_13" />

                        <!-- City Name label -->
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_large"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_semi_bold"
                            android:includeFontPadding="false"
                            android:text="@string/labelCityName"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_13" />

                        <!-- City dropdown anchor -->
                        <FrameLayout
                            android:id="@+id/flCityAnchor"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/margin_small"
                            android:background="@drawable/bg_input_field"
                            android:clickable="true"
                            android:focusable="true"
                            android:onClickListener="@{onClickListener}">

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tvCity"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:ellipsize="end"
                                android:fontFamily="@font/proza_libre_medium"
                                android:gravity="center_vertical"
                                android:hint="@string/hintSelectCity"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:paddingHorizontal="@dimen/margin_small"
                                android:paddingEnd="@dimen/icon_xlarge"
                                android:singleLine="true"
                                android:textColor="@color/black"
                                android:textColorHint="?attr/colorTextHint"
                                android:textSize="@dimen/text_size_13" />

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/ivCityArrow"
                                android:layout_width="@dimen/icon_small"
                                android:layout_height="@dimen/icon_small"
                                android:layout_gravity="center_vertical|end"
                                android:layout_marginEnd="@dimen/margin_large"
                                android:src="@drawable/ic_down_arrow" />

                        </FrameLayout>

                        <!-- Email label -->
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_large"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_semi_bold"
                            android:includeFontPadding="false"
                            android:text="@string/labelEmailAddress"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Email input -->
                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/margin_small"
                            android:background="@drawable/bg_input_field"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_medium"
                            android:hint="@string/hintEmail"
                            android:includeFontPadding="false"
                            android:inputType="textEmailAddress"
                            android:maxLength="100"
                            android:maxLines="1"
                            android:paddingHorizontal="@dimen/margin_small"
                            android:singleLine="true"
                            android:textColor="@color/black"
                            android:textColorHint="?attr/colorTextHint"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Pan Card Number label -->
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_large"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_semi_bold"
                            android:includeFontPadding="false"
                            android:text="@string/labelPanCardNumber"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Pan Card Number input -->
                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/etPan"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/margin_small"
                            android:background="@drawable/bg_input_field"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_medium"
                            android:hint="@string/hintPanCardNumber"
                            android:includeFontPadding="false"
                            android:inputType="textCapCharacters|textNoSuggestions"
                            android:maxLength="10"
                            android:maxLines="1"
                            android:paddingHorizontal="@dimen/margin_small"
                            android:singleLine="true"
                            android:textColor="@color/black"
                            android:textColorHint="?attr/colorTextHint"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Aadhar Card Number label -->
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_large"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_semi_bold"
                            android:includeFontPadding="false"
                            android:text="@string/labelAadharCardNumber"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Aadhar Card Number input -->
                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/etAadhar"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/margin_small"
                            android:background="@drawable/bg_input_field"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_medium"
                            android:hint="@string/hintAadharCardNumber"
                            android:includeFontPadding="false"
                            android:inputType="number"
                            android:maxLength="12"
                            android:maxLines="1"
                            android:paddingHorizontal="@dimen/margin_small"
                            android:singleLine="true"
                            android:textColor="@color/black"
                            android:textColorHint="?attr/colorTextHint"
                            android:textSize="@dimen/text_size_13" />

                        <!-- GST Number label -->
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_large"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_semi_bold"
                            android:includeFontPadding="false"
                            android:text="@string/labelGstNumber"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_13" />

                        <!-- GST Number input -->
                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/etGst"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/margin_small"
                            android:background="@drawable/bg_input_field"
                            android:ellipsize="end"
                            android:fontFamily="@font/proza_libre_medium"
                            android:hint="@string/hintGstNumber"
                            android:includeFontPadding="false"
                            android:inputType="textCapCharacters|textNoSuggestions"
                            android:maxLength="15"
                            android:maxLines="1"
                            android:paddingHorizontal="@dimen/margin_small"
                            android:singleLine="true"
                            android:textColor="@color/black"
                            android:textColorHint="?attr/colorTextHint"
                            android:textSize="@dimen/text_size_13" />

                        <!-- Create Virtual Account button -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/button_height"
                            android:layout_marginTop="@dimen/margin_extra_large"
                            android:layout_marginBottom="@dimen/margin_small"
                            app:cardBackgroundColor="?attr/colorPrimary"
                            app:cardCornerRadius="@dimen/button_corner_radius"
                            app:cardElevation="@dimen/card_elevation">

                            <LinearLayout
                                android:id="@+id/llSubmit"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?selectableItemBackground"
                                android:gravity="center"
                                android:onClickListener="@{onClickListener}"
                                android:orientation="horizontal"
                                android:visibility="@{showProgress ? View.INVISIBLE : View.VISIBLE}">

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/btnSubmit"
                                    android:textColor="@color/white"
                                    android:textSize="@dimen/text_size_16"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <ProgressBar
                                android:id="@+id/progressBar"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginVertical="@dimen/margin_small"
                                android:indeterminateTint="@color/white"
                                android:visibility="@{showProgress ? View.VISIBLE : View.GONE}"
                                tools:visibility="gone" />

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
