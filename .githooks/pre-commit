#!/bin/sh

echo "Running pre-commit checks..."

branch="$(git rev-parse --abbrev-ref HEAD)"

# Block commit on main branch
if [ "$branch" = "main" ]; then
    echo "❌ Direct commit to MAIN branch is not allowed."
    exit 1
fi

# Check for Android debug logs
if git grep -nE 'Log\.[deivw]\s*\(|Utility\.printLog\s*\(' -- '*.kt' '*.java'
then
    echo ""
    echo "❌ Commit blocked: Debug logs found."
    echo "Please remove Log.d(), Log.e(), Log.i(), Log.v(), Log.w() or Utility.printLog() calls."
    exit 1
fi

echo "✅ Commit allowed for branch: $branch"
exit 0